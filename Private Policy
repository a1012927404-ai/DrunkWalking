<script>
    function switchLang(lang) {
        // 更新tab样式
        document.querySelectorAll('.lang-tab').forEach(tab => tab.classList.remove('active'));
        event.target.classList.add('active');
        
        // 更新政策显示
        document.querySelectorAll('.policy').forEach(policy => policy.classList.remove('active'));
        document.getElementById('policy-' + lang).classList.add('active');
    }
</script>
