        // 更新tab样式
        document.querySelectorAll('.lang-tab').forEach(tab => tab.classList.remove('active'));
        // 找到被点击的tab并激活
        const tabs = document.querySelectorAll('.lang-tab');
        tabs.forEach(tab => {
            if (tab.textContent.includes(lang === 'zh' ? '中文' : 'English')) {
                tab.classList.add('active');
            }
        });
        
        // 更新支持页面显示
        document.querySelectorAll('.support').forEach(support => support.classList.remove('active'));
        document.getElementById('support-' + lang).classList.add('active');
    }
